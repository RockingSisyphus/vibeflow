{
  "nodesets": [
    {
      "name": "loop.retry_step",
      "display_name": "Retry Step",
      "category": "loop",
      "description": "Increments loop.current and reports whether the retry loop should stop.",
      "version": "0.1.0",
      "purity": "pure",
      "requires": [{"type": "loop.current", "cardinality": "exactly_one"}],
      "provides": [
        {"key": "loop.next", "type": "loop.next"},
        {"key": "loop.done", "type": "loop.done"}
      ],
      "exports": [
        {"key": "loop.next", "type": "loop.next"},
        {"key": "loop.done", "type": "loop.done"}
      ],
      "pipeline": {
        "inputs": [{"key": "loop.current", "type": "loop.current"}],
        "nodes": [
          {"name": "start", "type": "sandbox.start", "display_name": "Body Start", "description": "Starts one while-loop retry body invocation."},
          {
            "name": "increment",
            "type": "semantic.increment_until",
            "display_name": "Increment",
            "description": "Moves the retry value toward the target.",
            "requires": [{"type": "loop.current", "cardinality": "exactly_one"}],
            "provides": [{"key": "loop.next", "type": "loop.next"}],
            "step": 2
          },
          {
            "name": "done",
            "type": "semantic.loop_done_value",
            "display_name": "Done Check",
            "description": "Checks whether loop.next has reached the retry target.",
            "requires": [{"type": "loop.next", "cardinality": "exactly_one"}],
            "provides": [{"key": "loop.done", "type": "loop.done"}],
            "target": 7
          },
          {
            "name": "end",
            "type": "sandbox.start",
            "display_name": "Body End",
            "description": "Ends a body iteration after loop.next and loop.done are available."
          }
        ],
        "edges": [
          {"from": "start", "to": "increment"},
          {"from": "increment", "to": "done"},
          {"from": "done", "to": "end"}
        ],
        "outputs": [
          {"type": "loop.next", "cardinality": "exactly_one"},
          {"type": "loop.done", "cardinality": "exactly_one"}
        ]
      }
    }
  ],
  "pipeline": {
    "inputs": [{"key": "loop.current", "type": "loop.current"}],
    "max_steps": 10,
    "nodes": [
      {"name": "start", "type": "sandbox.start", "display_name": "Start", "description": "Starts the first-class while loop example."},
      {
        "name": "retry_loop",
        "type": "vibeflow.loop.while",
        "display_name": "Retry Loop",
        "description": "Runs a retry body until loop.done becomes true.",
        "requires": [{"type": "loop.current", "cardinality": "exactly_one"}],
        "provides": [
          {"key": "loop.next", "type": "loop.next"},
          {"key": "loop.done", "type": "loop.done"},
          {"key": "loop.iterations", "type": "loop.iterations"}
        ],
        "loop": {
          "body": "loop.retry_step",
          "max_iterations": 5,
          "carry": [
            {"from": "loop.current", "as": "loop.current", "update": "loop.next"}
          ],
          "outputs": [
            {"from": "loop.next", "as": "loop.next"},
            {"from": "loop.done", "as": "loop.done"},
            {"from": "loop.iterations", "as": "loop.iterations"}
          ],
          "stop_when": {"from": "loop.done", "equals": true}
        }
      },
      {
        "name": "end",
        "type": "semantic.loop_end",
        "display_name": "End",
        "description": "Ends after the while loop produces loop.next.",
        "requires": [{"type": "loop.next", "cardinality": "exactly_one"}]
      }
    ],
    "edges": [
      {"from": "start", "to": "retry_loop"},
      {"from": "retry_loop", "to": "end"}
    ],
    "outputs": [
      {"type": "loop.next", "cardinality": "exactly_one"},
      {"type": "loop.done", "cardinality": "exactly_one"},
      {"type": "loop.iterations", "cardinality": "exactly_one"}
    ]
  }
}
