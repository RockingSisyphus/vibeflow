{
  "pipeline": {
    "inputs": ["value.in"],
    "nodes": [
      {"name": "increment", "type": "sandbox.increment", "requires": ["value.in"], "provides": ["value.next"]},
      {"name": "copy", "type": "sandbox.copy_back", "requires": ["value.next"], "provides": ["value.in"]}
    ],
    "loops": [
      {
        "name": "count_loop",
        "edges": [["copy", "increment"]],
        "nodes": ["increment", "copy"],
        "max_iterations": 2
      }
    ]
  }
}
