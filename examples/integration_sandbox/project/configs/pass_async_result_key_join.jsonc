{
  "pipeline": {
    "nodes": [
      {
        "name": "start",
        "type": "sandbox.start"
      },
      {
        "name": "seed",
        "type": "sandbox.constant",
        "provides": [
          {
            "key": "value.in",
            "type": "value.in"
          }
        ],
        "async": "result_key",
        "result_key": "value.in",
        "value": 7
      },
      {
        "name": "add",
        "type": "sandbox.add",
        "requires": [
          {
            "type": "value.in",
            "cardinality": "exactly_one"
          }
        ],
        "provides": [
          {
            "key": "value.out",
            "type": "value.out"
          }
        ],
        "delta": 5
      },
      {
        "name": "end",
        "type": "sandbox.out_value_end",
        "requires": [
          {
            "type": "value.out",
            "cardinality": "exactly_one"
          }
        ]
      }
    ],
    "edges": [
      {
        "from": "start",
        "to": "seed"
      },
      {
        "from": "seed",
        "to": "add"
      },
      {
        "from": "add",
        "to": "end"
      }
    ],
    "outputs": [
      {
        "type": "value.out",
        "cardinality": "exactly_one"
      }
    ]
  }
}
