      ],
      "provides": [
        {
          "key": "value.final",
          "type": "value.final"
        }
      ],
      "exports": [
        {
          "key": "value.final",
          "type": "value.final"
        }
      ],
      "pipeline": {
        "inputs": [
          {
            "key": "value.in",
            "type": "value.in"
          }
        ],
        "nodes": [
          {
            "name": "start",
            "type": "sandbox.start"
          },
          {
            "name": "input",
            "type": "sandbox.value_input",
            "requires": [
              {
                "type": "value.in",
                "cardinality": "exactly_one"
              }
            ],
            "provides": [
              {
                "key": "value.in.input",
                "type": "value.in"
              }
            ]
          },
          {
            "name": "first",
            "type": "nodeset.math.add_one",
            "requires": [
              {
                "type": "value.in",
