            ],
            "provides": [
              {
                "key": "value.out",
                "type": "value.out"
              }
            ]
          },
          {
            "name": "second",
            "type": "sandbox.add_out",
            "requires": [
              {
                "type": "value.out",
                "cardinality": "exactly_one"
              }
            ],
            "provides": [
              {
                "key": "value.final",
                "type": "value.final"
              }
            ],
            "delta": 1
          },
          {
            "name": "end",
            "type": "sandbox.final_value_end",
            "requires": [
              {
                "type": "value.final",
                "cardinality": "exactly_one"
              }
            ]
          }
        ],
        "edges": [
          {
            "from": "start",
            "to": "input"
          },
          {
            "from": "input",
            "to": "first"
          },
          {
            "from": "first",
