            "cardinality": "exactly_one",
            "display_name": "Calc Sum"
          }
        ],
        "provides": [
          {
            "key": "calc.scaled",
            "type": "calc.scaled",
            "display_name": "Calc Scaled"
          }
        ],
        "factor": 3,
        "id": "scale",
        "type_used": "semantic.scale",
        "display_name": "Scale",
        "description": "Runs scale."
      },
      {
        "requires": [
          {
            "type": "calc.c",
            "cardinality": "exactly_one",
            "display_name": "Calc C"
          },
          {
            "type": "calc.d",
            "cardinality": "exactly_one",
            "display_name": "Calc D"
          }
        ],
        "provides": [
