{
  "plugins": [
    {
      "module": "plugins.py",
      "class": "Plugin",
      "type": "policy"
    }
  ],
  "base_lib": {
    "paths": [
      "base_lib"
    ],
    "modules": [
      {
        "module": "base_lib.math_tools",
        "status": "implemented"
      }
    ]
  },
  "nodesets": [
    {
      "name": "example.add_one",
      "display_name": "Example Add One",
      "category": "example",
      "description": "Composite nodeset that adds one to value.in.",
      "version": "0.1.0",
      "purity": "pure",
      "requires": [
        {
          "type": "value.in",
          "cardinality": "exactly_one"
        }
      ],
      "provides": [
        {
          "key": "value.out",
          "type": "value.out"
        }
      ],
      "exports": [
        {
          "key": "value.out",
          "type": "value.out"
        }
      ],
      "pipeline": {
        "inputs": [
          {
            "key": "value.in",
            "type": "value.in"
          }
        ],
        "nodes": [
          {
            "name": "start",
            "type": "example.start"
          },
          {
            "name": "add_one",
            "type": "example.add",
            "requires": [
              {
                "type": "value.in",
                "cardinality": "exactly_one"
              }
            ],
            "provides": [
              {
                "key": "value.out",
                "type": "value.out"
              }
            ],
            "delta": 1
          },
          {
            "name": "end",
            "type": "example.end",
            "requires": [
              {
                "type": "value.out",
                "cardinality": "exactly_one"
              }
            ]
          }
        ],
        "edges": [
          [
            "start",
            "add_one"
          ],
          [
            "add_one",
            "end"
          ]
        ],
        "outputs": [
          {
            "type": "value.out",
            "cardinality": "exactly_one"
          }
        ]
      }
    }
  ],
  "pipeline": {
    "nodes": [
      {
        "name": "start",
        "type": "example.start"
      },
      {
        "name": "seed",
        "type": "example.seed",
        "provides": [
          {
            "key": "value.in",
            "type": "value.in"
          }
        ],
        "value": 4
      },
      {
        "name": "add_one_flow",
        "type": "nodeset.example.add_one",
        "requires": [
          {
            "type": "value.in",
            "cardinality": "exactly_one"
          }
        ],
        "provides": [
          {
            "key": "value.out",
            "type": "value.out"
          }
        ]
      },
      {
        "name": "end",
        "type": "example.end",
        "requires": [
          {
            "type": "value.out",
            "cardinality": "exactly_one"
          }
        ]
      }
    ],
    "edges": [
      [
        "start",
        "seed"
      ],
      [
        "seed",
        "add_one_flow"
      ],
      [
        "add_one_flow",
        "end"
      ]
    ],
    "outputs": [
      {
        "type": "value.out",
        "cardinality": "exactly_one"
      }
    ]
  }
}
