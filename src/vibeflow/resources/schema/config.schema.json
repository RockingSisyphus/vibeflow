{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibeflow.local/schema/config.schema.json",
  "title": "VibeFlow Config",
  "type": "object",
  "properties": {
    "pipeline": { "$ref": "#/$defs/pipeline" },
    "nodes": { "$ref": "#/$defs/nodes" },
    "edges": { "$ref": "#/$defs/edges" },
    "max_steps": { "type": "integer", "minimum": 1 },
    "nodeset_imports": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "global_config": { "$ref": "#/$defs/scopedConfig" },
    "base_lib": {
      "type": "object",
      "properties": {
        "paths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "modules": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "object",
                "properties": {
                  "module": { "type": "string", "minLength": 1 },
                  "name": { "type": "string", "minLength": 1 },
                  "status": { "enum": ["planned", "implemented"] },
                  "display_name": { "type": "string" },
                  "category": { "type": "string" },
                  "description": { "type": "string" },
                  "version": { "type": "string" }
                },
                "anyOf": [
                  { "required": ["module"] },
                  { "required": ["name"] }
                ]
              }
            ]
          }
        }
      }
    },
    "policy": { "$ref": "policy.schema.json" },
    "plugins": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "properties": {
              "module": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "class": { "type": "string", "minLength": 1 },
              "factory": { "type": "string", "minLength": 1 },
              "type": { "enum": ["policy", "compiler", "runtime"] },
              "status": { "enum": ["planned", "implemented"] },
              "priority": { "type": "integer", "minimum": 1 },
              "enabled": { "type": "boolean" },
              "conflict": { "enum": ["error", "replace"] },
              "scope": { "type": "string" },
              "display_name": { "type": "string" },
              "category": { "type": "string" },
              "description": { "type": "string" },
              "version": { "type": "string" },
              "config": { "type": "object" },
              "settings": { "type": "object" }
            },
            "anyOf": [
              { "required": ["module"] },
              { "required": ["path"] },
              { "required": ["name"], "properties": { "status": { "const": "planned" } } }
            ]
          }
        ]
      }
    }
  },
  "$defs": {
    "dataProvider": {
      "type": "object",
      "required": ["key", "type", "display_name"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "dataRequirement": {
      "type": "object",
      "required": ["type", "cardinality", "display_name"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "cardinality": { "enum": ["exactly_one", "optional_one", "all"] },
        "display_name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "pipeline": {
      "type": "object",
      "required": ["nodes"],
      "properties": {
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/dataProvider" } },
        "outputs": { "type": "array", "items": { "$ref": "#/$defs/dataRequirement" } },
        "nodes": { "$ref": "#/$defs/nodes" },
        "edges": { "$ref": "#/$defs/edges" },
        "max_steps": { "type": "integer", "minimum": 1 }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type_used": { "type": "string", "minLength": 1 },
          "status": { "enum": ["planned", "implemented"] },
          "flow_kind": { "enum": ["terminal", "process", "decision", "io", "predefined", "data_store", "document", "preparation"] },
          "planned_behavior": { "$ref": "#/$defs/plannedBehavior" },
          "display_name": { "type": "string" },
          "description": { "type": "string" },
          "style": { "$ref": "#/$defs/nodeStyle" },
          "similar_to": { "$ref": "#/$defs/nodeSimilarity" },
          "join_policy": { "enum": ["safe_any", "any_active", "all"] },
          "loop": { "$ref": "#/$defs/loopSpec" },
          "requires": { "type": "array", "items": { "$ref": "#/$defs/dataRequirement" } },
          "provides": { "type": "array", "items": { "$ref": "#/$defs/dataProvider" } },
          "config": { "type": "object" },
          "node_configs": { "type": "object" },
          "allow_config_override": { "type": "boolean" },
          "override_child_config": { "type": "boolean" },
          "async": { "enum": ["detached", "result_key"] },
          "result_key": { "type": "string", "minLength": 1 }
        },
        "anyOf": [
          { "required": ["type_used"] },
          { "required": ["status", "flow_kind"], "properties": { "status": { "const": "planned" } } }
        ],
        "allOf": [
          {
            "if": { "properties": { "status": { "const": "planned" } }, "required": ["status"] },
            "then": true,
            "else": { "not": { "required": ["planned_behavior"] } }
          }
        ]
      }
    },
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "nodeStyle": {
      "type": "object",
      "properties": {
        "fill": { "$ref": "#/$defs/hexColor" },
        "stroke": { "$ref": "#/$defs/hexColor" },
        "text": { "$ref": "#/$defs/hexColor" }
      },
      "additionalProperties": false
    },
    "nodeSimilarity": {
      "type": "object",
      "required": ["node", "relationship", "reason"],
      "properties": {
        "node": { "type": "string", "minLength": 1 },
        "relationship": { "enum": ["variant", "copy"] },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "loopSpec": {
      "type": "object",
      "required": ["body"],
      "oneOf": [
        { "required": ["stop_after"], "not": { "required": ["stop_when"] } },
        { "required": ["stop_when"], "not": { "required": ["stop_after"] } }
      ],
      "properties": {
        "body": { "type": "string", "minLength": 1 },
        "max_iterations": { "type": "integer", "minimum": 1 },
        "stop_after": { "type": "integer", "minimum": 1 },
        "stop_when": {
          "type": "object",
          "required": ["from"],
          "properties": {
            "from": { "type": "string", "minLength": 1 },
            "equals": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "carry": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "as", "update"],
            "properties": {
              "from": { "type": "string", "minLength": 1 },
              "as": { "type": "string", "minLength": 1 },
              "update": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "collect": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "as"],
            "properties": {
              "from": { "type": "string", "minLength": 1 },
              "as": { "type": "string", "minLength": 1 },
              "mode": { "const": "all" }
            },
            "additionalProperties": false
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "as"],
            "properties": {
              "from": { "type": "string", "minLength": 1 },
              "as": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "scopedConfig": {
      "type": "object",
      "properties": {
        "config": { "type": "object" },
        "values": { "type": "object" },
        "allow_config_override": { "type": "boolean" },
        "override_child_config": { "type": "boolean" }
      }
    },
    "plannedBehavior": {
      "oneOf": [
        { "enum": ["blocking", "transparent"] },
        {
          "type": "object",
          "required": ["kind", "stub_module"],
          "properties": {
            "kind": { "const": "python_stub" },
            "stub_module": {
              "type": "string",
              "pattern": "^project/stubs/[^.][^\\n\\r]*\\.py$"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "edges": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "string", "minLength": 1 }
          },
          {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string", "minLength": 1 },
              "to": { "type": "string", "minLength": 1 },
              "when": { "type": "string" }
            }
          }
        ]
      }
    }
  }
}
