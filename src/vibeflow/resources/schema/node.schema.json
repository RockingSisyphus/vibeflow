{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibeflow.local/schema/node.schema.json",
  "title": "VibeFlow Node",
  "type": "object",
  "required": ["NODE_INFO", "CONTRACT", "run_pure"],
  "properties": {
    "NODE_INFO": {
      "type": "object",
      "required": ["type_key", "display_name", "category", "description", "version", "purity"],
      "properties": {
        "type_key": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "purity": { "type": "string", "const": "pure" }
      }
    },
    "CONTRACT": {
      "$ref": "#/$defs/contract"
    },
    "run_pure": {
      "description": "Python method with signature run_pure(self, inputs, params).",
      "type": "string"
    }
  },
  "$defs": {
    "contract": {
      "type": "object",
      "required": ["requires", "provides", "input_semantics", "output_semantics", "params_schema", "output_schema"],
      "properties": {
        "requires": { "type": "array", "items": { "$ref": "#/$defs/dataRequirement" } },
        "provides": { "type": "array", "items": { "$ref": "#/$defs/dataProvider" } },
        "input_semantics": { "type": "object" },
        "output_semantics": { "type": "object" },
        "params_schema": { "type": "object" },
        "output_schema": { "type": "object" },
        "examples": { "type": "array", "items": { "type": "object" } }
      }
    },
    "dataProvider": {
      "type": "object",
      "required": ["key", "type"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "dataRequirement": {
      "type": "object",
      "required": ["type", "cardinality"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "cardinality": { "enum": ["exactly_one", "optional_one", "all"] }
      },
      "additionalProperties": false
    }
  }
}
